{
  "name": "coipia-albeiro",
  "version": "2.0.0",
  "description": "Bot de Discord con reproductor de música y quiz musical",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/index.js\""
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/voice": "^0.17.0",
    "@snazzah/davey": "^0.1.11",
    "discord-api-types": "^0.38.47",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "^3.0.0-beta.4",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.13",
    "mediaplex": "^1.0.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "spotify-url-info": "^3.3.0",
    "youtube-dl-exec": "^3.1.6"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "nodemon": "^3.1.0",
    "typescript": "^5.4.5"
  },
  "license": "ISC"
}
